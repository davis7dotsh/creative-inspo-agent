{
  "name": "@creative-agent/assets-explorer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -b && vite build && tsc -p tsconfig.server.build.json",
    "check": "tsc -b --pretty false && pnpm run check:effect",
    "check:effect": "effect-tsgo diagnostics --project tsconfig.server.json --format pretty --strict",
    "dev": "node scripts/dev.mjs",
    "dev:api": "tsx watch src/server/main.ts",
    "dev:web": "vite --host 127.0.0.1",
    "format": "biome format --config-path=../../biome.json --write .",
    "format:check": "biome format --config-path=../../biome.json .",
    "lint": "biome lint --config-path=../../biome.json .",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "validate": "pnpm format:check && pnpm check && pnpm lint && pnpm test && pnpm build"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.100",
    "@effect/sql-sqlite-node": "4.0.0-beta.100",
    "@tailwindcss/vite": "4.1.18",
    "effect": "4.0.0-beta.100",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwindcss": "4.1.18"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@effect/tsgo": "0.24.1",
    "@types/node": "24.10.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vite": "7.3.1",
    "vitest": "4.1.10"
  }
}
