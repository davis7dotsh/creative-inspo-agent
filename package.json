{
  "name": "creative-agent",
  "version": "0.1.0",
  "description": "Local-first YouTube inspiration library for Codex agents",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "creative-agent": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "pnpm run check:types && pnpm run check:effect",
    "check:effect": "effect-tsgo diagnostics --project tsconfig.json --format pretty --strict",
    "check:types": "tsc --noEmit -p tsconfig.json",
    "cli": "node --import tsx src/cli.ts",
    "dev": "tsx src/cli.ts",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "precheck:effect": "node scripts/ensure-effect-tsgo-executable.mjs",
    "test": "vitest run",
    "validate": "pnpm run format:check && pnpm run check && pnpm run lint && pnpm run test && pnpm run build && pnpm run validate:skills",
    "validate:skills": "node scripts/validate-skills.mjs"
  },
  "packageManager": "pnpm@11.10.0",
  "type": "module",
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.100",
    "@effect/sql-sqlite-node": "4.0.0-beta.100",
    "effect": "4.0.0-beta.100",
    "sqlite-vec": "0.1.9"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@effect/tsgo": "0.24.1",
    "@types/node": "24.10.1",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10",
    "yaml": "2.9.0"
  }
}
